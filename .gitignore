# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.coverage
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Generated artifacts — regenerated by renderers, never committed
samples/*.docx
samples/*.json
!samples/.gitkeep

# Evidence collection output — contains live data, never commit
evidence-output/
*.evidence.json
*.evidence.metadata.json

# MkDocs build output
docs/site/
site/

# Terraform
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.tfstate.lock.info
crash.log

# Local environment overrides
.env
.env.local
*.secret
